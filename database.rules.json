{
  "rules": {
    "sessions": {
      "$sessionCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "currentPhase": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 4"
        },
        "presence": {
          "$studentId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $studentId"
          }
        }
      }
    }
  }
}
